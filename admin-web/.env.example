# admin-web — copy to .env and fill in your local values
#
# ── Option A: single API Gateway base URL (default / recommended) ─────────────
# All admin-web traffic goes through the one gateway host (:8080). YARP strips
# the leading prefix and fans in to the 3 consolidated hosts:
#   /identity, /engagement                     → core       (5050)
#   /catalog, /orders, /warehouse, /logistics  → operations (5002)
#   /commerce, /finance, /analytics            → commerce   (5005)
# Zero URL-path changes in any API call — client.ts uses each URL as an axios
# baseURL and the call paths stay /api/v1/...; the gateway prefix routes them.
# Benefits: single origin (one CORS surface), centralized rate limiting, and in
# production the service ports can be firewalled so only the gateway is exposed.
#
VITE_IDENTITY_URL=http://localhost:8080/identity
VITE_CATALOG_URL=http://localhost:8080/catalog
VITE_ORDERS_URL=http://localhost:8080/orders
VITE_WAREHOUSE_URL=http://localhost:8080/warehouse
VITE_LOGISTICS_URL=http://localhost:8080/logistics
VITE_COMMERCE_URL=http://localhost:8080/commerce
VITE_FINANCE_URL=http://localhost:8080/finance
VITE_ENGAGEMENT_URL=http://localhost:8080/engagement
VITE_ANALYTICS_URL=http://localhost:8080/analytics

# Production: replace http://localhost:8080 with your real gateway URL
# (e.g. https://api.laundryghar.com) — the /prefix paths stay the same.

# ── Option B: direct per-consolidated-host URLs (gateway-bypass fallback) ─────
# Use only when you need to hit a host directly while the gateway is not running.
# Post-consolidation the 11 services collapsed to 3 hosts:
#   core (5050) = identity + engagement
#   operations (5002) = catalog + orders + warehouse + logistics
#   commerce (5005) = commerce + finance + analytics
#
# VITE_IDENTITY_URL=http://localhost:5050
# VITE_CATALOG_URL=http://localhost:5002
# VITE_ORDERS_URL=http://localhost:5002
# VITE_WAREHOUSE_URL=http://localhost:5002
# VITE_LOGISTICS_URL=http://localhost:5002
# VITE_COMMERCE_URL=http://localhost:5005
# VITE_FINANCE_URL=http://localhost:5005
# VITE_ENGAGEMENT_URL=http://localhost:5050
# VITE_ANALYTICS_URL=http://localhost:5005
