# admin-web — copy to .env and fill in your local values
#
# ── Option A: direct per-consolidated-service URLs (current default) ─────────
# Post-consolidation the 11 services collapsed to 3 hosts:
#   core (5050)       = identity + engagement
#   operations (5002) = catalog + orders + warehouse + logistics
#   commerce (5005)   = commerce + finance + analytics
# Use this if you need to hit a service directly while the gateway is not running.
#
VITE_IDENTITY_URL=http://localhost:5050
VITE_CATALOG_URL=http://localhost:5002
VITE_ORDERS_URL=http://localhost:5002
VITE_WAREHOUSE_URL=http://localhost:5002
VITE_LOGISTICS_URL=http://localhost:5002
VITE_COMMERCE_URL=http://localhost:5005
VITE_FINANCE_URL=http://localhost:5005
VITE_ENGAGEMENT_URL=http://localhost:5050
VITE_ANALYTICS_URL=http://localhost:5005

# ── Option B: single gateway base URL (recommended migration path) ────────────
# When adopting the API Gateway (R3-GW-1), replace all per-service URLs above
# with path-prefixed URLs under the single gateway host (http://localhost:8080).
# No URL-path changes in any API call are required — only the host changes.
# Uncomment the block below and comment out the per-service block above.
#
# GATEWAY_BASE=http://localhost:8080
#
# VITE_IDENTITY_URL=${GATEWAY_BASE}/identity
# VITE_CATALOG_URL=${GATEWAY_BASE}/catalog
# VITE_ORDERS_URL=${GATEWAY_BASE}/orders
# VITE_WAREHOUSE_URL=${GATEWAY_BASE}/warehouse
# VITE_LOGISTICS_URL=${GATEWAY_BASE}/logistics
# VITE_COMMERCE_URL=${GATEWAY_BASE}/commerce
# VITE_FINANCE_URL=${GATEWAY_BASE}/finance
# VITE_ENGAGEMENT_URL=${GATEWAY_BASE}/engagement
# VITE_ANALYTICS_URL=${GATEWAY_BASE}/analytics
#
# Production: set GATEWAY_BASE to your real gateway URL (e.g. https://api.laundryghar.com)
# and leave the path-prefix lines uncommented.
