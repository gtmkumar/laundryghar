# -------------------------------------------------------------------------
# customer-mobile environment variables
#
# Copy to .env.local and fill in values for local / CI / EAS builds.
# NEVER commit a real .env file — .env.local is gitignored.
# -------------------------------------------------------------------------

# --- Service URLs (leave blank in plain dev; config.ts derives from Metro) ---
# IDENTITY_API_URL=http://192.168.1.x:5050
# CATALOG_API_URL=http://192.168.1.x:5001
# ORDERS_API_URL=http://192.168.1.x:5002
# COMMERCE_API_URL=http://192.168.1.x:5005
# ENGAGEMENT_API_URL=http://192.168.1.x:5007
# DEFAULT_BRAND_CODE=LG-MAIN

# --- Sentry crash reporting ---
# Obtain your DSN from https://sentry.io → Project → Settings → Client Keys
# When blank, Sentry is fully disabled (no network calls, no overhead).
# In dev (__DEV__ === true) Sentry is always disabled even when DSN is set.
# EXPO_PUBLIC_SENTRY_DSN=https://XXXX@oXXX.ingest.sentry.io/YYYY
