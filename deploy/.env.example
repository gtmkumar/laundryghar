# Copy to .env (git-ignored) and fill in. Never commit real values.

# ── Database (external / managed) ────────────────────────────────────────────
# MUST be a non-superuser role (app_user) so PostgreSQL RLS is enforced.
DB_CONNECTION_STRING=Host=db.internal;Port=5432;Database=laundry_ghar_db;Username=app_user;Password=CHANGE_ME

# ── Secrets ──────────────────────────────────────────────────────────────────
# 32-byte base64 key for PII column encryption:  openssl rand -base64 32
PII_ENCRYPTION_KEY=CHANGE_ME
# RSA private key PEM (single line with \n, or use a secrets provider — see
# PRODUCTION_ENV.md "Secrets abstraction"). Generate:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048
JWT_PRIVATE_KEY=CHANGE_ME

# ── Public endpoints ─────────────────────────────────────────────────────────
# URL clients use to reach the gateway (behind your TLS-terminating proxy).
PUBLIC_API_URL=https://api.example.com
# Origin of the admin web app (CORS allow-list on the gateway).
ADMIN_WEB_ORIGIN=https://admin.example.com

# ── Ports on the host ────────────────────────────────────────────────────────
GATEWAY_PORT=8080
ADMIN_WEB_PORT=8081

# ── Error tracking (optional) ────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ── Only for `--profile local-db` (staging with bundled postgres) ────────────
POSTGRES_DB=laundry_ghar_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
