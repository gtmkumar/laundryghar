<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>laundryghar.Gateway</RootNamespace>
    <AssemblyName>laundryghar.Gateway</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\laundryghar.ServiceDefaults\laundryghar.ServiceDefaults.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- YARP reverse proxy — latest stable, supports .NET 10 -->
    <PackageReference Include="Yarp.ReverseProxy" Version="2.3.0" />
    <!-- Built-in rate limiting is in-box from .NET 7+; no extra package needed -->
  </ItemGroup>

</Project>
