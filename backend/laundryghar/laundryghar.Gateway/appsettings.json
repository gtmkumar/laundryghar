{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ── Gateway — upstream cluster destinations ────────────────────────────────
  // Override any value via env var using double-underscore notation, e.g.:
  //   Gateway__Clusters__identity__Destinations__primary__Address=https://identity.prod.internal
  // All values here are dev defaults; production must supply real addresses
  // via environment variables or a secrets provider.
  //
  // Post-consolidation the 9 path prefixes fan in to 3 services:
  //   identity, engagement, mcp                    → core       @5050
  //   catalog, orders, warehouse, logistics        → operations @5002
  //   commerce, finance, analytics                 → commerce   @5005
  "Gateway": {
    "Clusters": {
      "identity":   { "Destinations": { "primary": { "Address": "http://localhost:5050" } } },
      "engagement": { "Destinations": { "primary": { "Address": "http://localhost:5050" } } },
      "mcp":        { "Destinations": { "primary": { "Address": "http://localhost:5050" } } },
      "catalog":    { "Destinations": { "primary": { "Address": "http://localhost:5002" } } },
      "orders":     { "Destinations": { "primary": { "Address": "http://localhost:5002" } } },
      "warehouse":  { "Destinations": { "primary": { "Address": "http://localhost:5002" } } },
      "logistics":  { "Destinations": { "primary": { "Address": "http://localhost:5002" } } },
      "commerce":   { "Destinations": { "primary": { "Address": "http://localhost:5005" } } },
      "finance":    { "Destinations": { "primary": { "Address": "http://localhost:5005" } } },
      "analytics":  { "Destinations": { "primary": { "Address": "http://localhost:5005" } } }
    }
  },

  // ── Global rate limiter ────────────────────────────────────────────────────
  // 300 requests per client IP per 60-second window.
  // Auth paths (/identity/connect/*, /identity/api/v1/auth/*) typically hit
  // Identity's own stricter limiter — this global cap is a backstop only.
  "RateLimit": {
    "PermitLimit": 300,
    "WindowSeconds": 60
  },

  // ── CORS — configured origins ──────────────────────────────────────────────
  // Dev defaults are baked into Program.cs.
  // In non-dev environments add origins here (or via env var):
  //   Cors__AllowedOrigins__0=https://admin.laundryghar.com
  "Cors": {
    "AllowedOrigins": []
  }
}
