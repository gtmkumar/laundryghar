{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Worker": {
    "NotificationPollIntervalSeconds": 5,
    "EventRelayPollIntervalSeconds": 5,
    "NotificationBatchSize": 20,
    "EventBatchSize": 20,
    "EventMaxAttempts": 10
  }
}
