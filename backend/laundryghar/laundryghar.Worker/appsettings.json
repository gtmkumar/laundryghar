{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "Worker": {
    "NotificationPollIntervalSeconds": 5,
    "EventRelayPollIntervalSeconds": 5,
    "NotificationBatchSize": 20,
    "EventBatchSize": 20,
    "EventMaxAttempts": 10,
    "ErasurePollIntervalSeconds": 3600,
    "ErasureGracePeriodDays": 30,
    "ErasureGracePeriodMinutesOverride": 0,
    "ErasureBatchSize": 10,
    "RetentionSweepIntervalSeconds": 86400,
    "NotificationOutboxRetentionDays": 180,
    "OtpCodeRetentionDays": 30,
    "RefreshTokenRetentionDays": 90,
    "DailyReconEnabled": false,
    "DailyReconHourLocal": 21,
    "ReconStaleHours": 12,
    "AutoDispatchEnabled": false,
    "AutoDispatchPollSeconds": 30,
    "AutoDispatchMinAgeMinutes": 2,
    "AutoDispatchMaxPerCycle": 10
  }
}
