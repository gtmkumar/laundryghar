{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "laundryghar-identity",
    "Audience": "laundryghar-services",
    "AccessMinutes": 15,
    "RefreshDays": 30
  },
  "Otp": {
    "TtlMinutes": 5,
    "MaxAttempts": 3,
    "ResendCooldownSeconds": 60,
    "LockoutWindowMinutes": 15,
    "LockoutThreshold": 10,
    "LockoutDurationMinutes": 15
    // HmacKey: inject via Otp__HmacKey env var in Production (32-byte base64).
    // Development uses a static well-known dev key automatically when HmacKey is absent.
  },
  "CustomerAuth": {
    // DefaultBrandCode is used when no X-Brand-Id header or brandCode body param is provided.
    // Set to the seeded brand's code. Override per deployment.
    "DefaultBrandCode": "LG-MAIN"
  },
  "DownstreamServices": {
    // Catalog + Orders are being consolidated into laundryghar.Operations on port 5002.
    "CatalogBaseUrl": "http://localhost:5002",
    "OrdersBaseUrl": "http://localhost:5002"
  },
  "OAuthResource": {
    // MCP runs in-process with Identity now; both default to this service's own port 5050.
    "McpBaseUrl": "http://localhost:5050",
    "IdentityBaseUrl": "http://localhost:5050"
  },
  "HealthChecks": {
    "NpgsqlConnectionString": "Host=localhost;Port=5432;Database=laundry_ghar_db;Username=postgres;Password=postgres"
  }
}
