{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "ModelContextProtocol": "Debug"
    }
  },
  "Jwt": {
    // In-process issuer. Authority points at this same service's discovery document so the
    // JWKS-validating "mcp" scheme can resolve keys without a cross-service hop (it is the
    // same process). Identity-origin endpoints validate with the in-process signing key.
    "Authority": "http://localhost:5050"
  },
  "Otp": {
    "TestCode": "123456"
  },
  "RateLimit": {
    "AuthPermitLimit": 30
  },
  "DownstreamServices": {
    "CatalogBaseUrl": "http://localhost:5002",
    "OrdersBaseUrl": "http://localhost:5002"
  },
  "OAuthResource": {
    "McpBaseUrl": "http://localhost:5050",
    "IdentityBaseUrl": "http://localhost:5050"
  },
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=laundry_ghar_db;Username=app_user;Password=app_user",
    "Admin": "Host=localhost;Port=5432;Database=laundry_ghar_db;Username=postgres;Password=postgres"
  }
}
