{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*",

  "Jwt": {
    "Issuer": "laundryghar-identity",
    "Audience": "laundryghar-services",
    "AccessMinutes": 15,
    "RefreshDays": 30
  },

  "CustomerAuth": {
    "DefaultBrandCode": "LG-MAIN"
  },

  "PublicBaseUrls": {
    "Commerce": "http://localhost:5005"
  },

  "Analytics": {
    "MatviewRefreshMinutes": 5
  },

  "Worker": {
    "NotificationPollIntervalSeconds": 5,
    "EventRelayPollIntervalSeconds": 5,
    "NotificationBatchSize": 20,
    "EventBatchSize": 20,
    "EventMaxAttempts": 10,
    "ErasurePollIntervalSeconds": 3600,
    "ErasureGracePeriodDays": 30,
    "ErasureGracePeriodMinutesOverride": 0,
    "ErasureBatchSize": 10,
    "RetentionSweepIntervalSeconds": 86400,
    "NotificationOutboxRetentionDays": 180,
    "OtpCodeRetentionDays": 30,
    "RefreshTokenRetentionDays": 90,
    "RoyaltyGenerationEnabled": false,
    "RoyaltyGenerationDayOfMonth": 1,
    "RoyaltyGenerationPollIntervalSeconds": 86400,
    "DailyReconEnabled": false,
    "DailyReconHourLocal": 21,
    "ReconStaleHours": 12,
    "SubscriptionBillingEnabled": false,
    "SubscriptionBillingPollIntervalSeconds": 86400,
    "SubscriptionMaxDunningAttempts": 3,
    "SubscriptionDunningBackoffMinutes": 1440,
    "AutoDispatchEnabled": false,
    "AutoDispatchPollSeconds": 30,
    "AutoDispatchMinAgeMinutes": 2,
    "AutoDispatchMaxPerCycle": 10
  },

  "Notifications": {
    "WhatsApp": {
      "Enabled": false,
      "AccessToken": "",
      "PhoneNumberId": ""
    },
    "Sms": {
      "Enabled": false,
      "AuthKey": "",
      "SenderId": "",
      "DltTemplateId": ""
    },
    "Push": {
      "Enabled": false,
      "AccessToken": ""
    }
  },

  "Razorpay": {
    "KeyId": "",
    "KeySecret": "",
    "WebhookSecret": ""
  }
}
