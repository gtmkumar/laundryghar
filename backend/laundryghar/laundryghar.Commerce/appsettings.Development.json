{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },

  "Jwt": {
    "Authority": "http://localhost:5050"
  },

  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5432;Database=laundry_ghar_db;Username=app_user;Password=app_user",
    "Admin": "Host=localhost;Port=5432;Database=laundry_ghar_db;Username=postgres;Password=postgres"
  },

  "Worker": {
    "ErasurePollIntervalSeconds": 60,
    "ErasureGracePeriodMinutesOverride": 2,
    "RetentionSweepIntervalSeconds": 300,
    "AutoDispatchEnabled": false,
    "AutoDispatchPollSeconds": 10,
    "AutoDispatchMinAgeMinutes": 0,
    "AutoDispatchMaxPerCycle": 5,
    "DailyReconEnabled": false,
    "DailyReconHourLocal": 17
  }
}
