# POS Web — copy to .env and fill in your local values

# Identity service (port 5000)
VITE_IDENTITY_URL=http://localhost:5050

# Catalog service (port 5001)
VITE_CATALOG_URL=http://localhost:5001

# Orders service (port 5002)
VITE_ORDERS_URL=http://localhost:5002

# Finance service (port 5006)
VITE_FINANCE_URL=http://localhost:5006

# Commerce service (port 5005)
VITE_COMMERCE_URL=http://localhost:5005
